<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer glass ring indicator -->
    <path
        android:pathData="M 54,20 A 34,34 0 1,1 53.9,20"
        android:strokeWidth="2.5"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.15" />
    
    <!-- Outer accent cyan dots -->
    <path
        android:pathData="M54,16 A 4,4 0 1,1 53.9,16"
        android:fillColor="#00F0FF" />

    <!-- Sleek Neon "N" Book Overlay paths -->
    <!-- First page backing shadow -->
    <path
        android:pathData="M38,34 L48,30 L72,30 L66,74 L42,74 Z"
        android:fillColor="#151A2E"
        android:fillAlpha="0.5" />

    <!-- Main Notebook Cover (Glassmorphic look) -->
    <path
        android:pathData="M40,32 L68,32 C70.2,32 72,33.8 72,36 L72,72 C72,74.2 70.2,76 68,76 L40,76 C37.8,76 36,74.2 36,72 L36,36 C36,33.8 37.8,32 40,32 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="36"
                android:startY="32"
                android:endX="72"
                android:endY="76"
                android:type="linear">
                <item android:color="#2D304B" android:offset="0.0" />
                <item android:color="#1B1C2E" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing Cyberpunk vertical strip representing the Note Spine / Binding dots -->
    <path
        android:pathData="M39,36 L42,36 L42,72 L39,72 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="39"
                android:startY="36"
                android:endX="42"
                android:endY="72"
                android:type="linear">
                <item android:color="#00F0FF" android:offset="0.0" />
                <item android:color="#0072FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Embossed letter 'N' on the cover -->
    <path
        android:pathData="M47,44 L47,64 M47,44 L61,64 M61,44 L61,64"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeAlpha="0.9" />

    <!-- A quick tech line decoration for high dynamic range look -->
    <path
        android:pathData="M48,68 L60,68"
        android:strokeColor="#00F0FF"
        android:strokeWidth="1.5" />
</vector>
